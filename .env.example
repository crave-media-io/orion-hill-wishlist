# Brevo API key — get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx

# Email address that receives wishlist submissions
NOTIFICATION_EMAIL=events@orionhillevents.com

# Sender email (must be verified domain in Brevo)
FROM_EMAIL=wishlist@orionhillevents.com
FROM_NAME=Orion Hill Events

# Comma-separated list of allowed origins (or * for all)
ALLOWED_ORIGINS=*
